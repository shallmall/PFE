FROM python:3.10-slim

WORKDIR /app

# Install PostgreSQL client dependencies
RUN apt-get update && apt-get install -y --no-install-recommends gcc libpq-dev && rm -rf /var/lib/apt/lists/*

# Install Python dependencies for Layer 2 Orchestrator
RUN pip install --no-cache-dir fastapi uvicorn pydantic sqlalchemy psycopg2-binary httpx

# Copy project files
COPY Deployment ./Deployment

EXPOSE 8001
CMD ["uvicorn", "Deployment.orchestrator.app:app", "--host", "0.0.0.0", "--port", "8001"]
